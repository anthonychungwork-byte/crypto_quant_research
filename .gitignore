# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
MANIFEST
build/
dist/

# ─────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────────────────────
# uv
# ─────────────────────────────────────────────────────────────────────────────
# Keep uv.lock committed for reproducibility; ignore uv cache only
.uv_cache/

# ─────────────────────────────────────────────────────────────────────────────
# Testing / coverage
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# ─────────────────────────────────────────────────────────────────────────────
# Type checking / linting
# ─────────────────────────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ─────────────────────────────────────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Project IP protection (HYBRID public/private strategy)
# Engine code is public; production parameters and live data are NOT
# ─────────────────────────────────────────────────────────────────────────────
configs/*.prod.yaml
configs/*.prod.yml
configs/secrets.yaml
configs/secrets.yml
results/live_pnl.csv
results/live_*.csv
results/prod_*.csv
results/POSTMORTEM_prod.md

# ─────────────────────────────────────────────────────────────────────────────
# Raw / processed data (too large for repo; keep folder structure via .gitkeep)
# ─────────────────────────────────────────────────────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────
# Generated figures / tables are COMMITTED so the rendered narrative is
# visible on GitHub. Only production-leaking artifacts are ignored above.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Logs / local env
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/
.env
.env.local
.envrc
